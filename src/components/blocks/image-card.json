{
  "collectionName": "components_blocks_image_card",
  "info": {
    "displayName": "Image Card",
    "icon": "image",
    "description": "Card-styled split: media (image or video) on one side, title + body + CTA on the other. Used as a top-level block and as a carousel slide."
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 160
    },
    "highlightedTitle": {
      "type": "string",
      "required": false,
      "maxLength": 160
    },
    "body": {
      "type": "text",
      "required": true,
      "maxLength": 600
    },
    "media": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.media",
      "required": true
    },
    "ctaLabel": {
      "type": "string",
      "required": false,
      "maxLength": 60
    },
    "ctaHref": {
      "type": "string",
      "required": false,
      "maxLength": 500
    },
    "imagePosition": {
      "type": "enumeration",
      "enum": ["left", "right"],
      "default": "left",
      "required": true
    }
  }
}
