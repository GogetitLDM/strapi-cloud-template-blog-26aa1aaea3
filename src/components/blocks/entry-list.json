{
  "collectionName": "components_blocks_entry_list",
  "info": {
    "displayName": "Entry List",
    "icon": "list",
    "description": "Section with tagline + heading + optional CTA, rendering a list of articles auto-fetched from the article collection"
  },
  "options": {},
  "attributes": {
    "tagline": {
      "type": "string",
      "required": false,
      "maxLength": 60
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "highlightedTitle": {
      "type": "string",
      "required": false,
      "maxLength": 80
    },
    "ctaLabel": {
      "type": "string",
      "required": false,
      "maxLength": 60
    },
    "ctaHref": {
      "type": "string",
      "required": false,
      "maxLength": 500
    },
    "linkLabel": {
      "type": "string",
      "required": false,
      "maxLength": 60,
      "default": "Leer más"
    },
    "limit": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 12,
      "default": 6
    },
    "sort": {
      "type": "enumeration",
      "required": true,
      "enum": ["publishedAt:desc", "publishedAt:asc", "title:asc", "title:desc"],
      "default": "publishedAt:desc"
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "tag": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tag.tag"
    }
  }
}
