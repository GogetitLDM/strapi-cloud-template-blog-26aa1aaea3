{
  "collectionName": "components_blocks_stat_item",
  "info": {
    "displayName": "Stat Item",
    "icon": "chart-line",
    "description": "Single statistic with animated number, title and description"
  },
  "options": {},
  "attributes": {
    "value": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "suffix": {
      "type": "string",
      "required": false,
      "maxLength": 8,
      "default": "+"
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "description": {
      "type": "text",
      "required": true,
      "maxLength": 240
    },
    "gradientReverse": {
      "type": "boolean",
      "required": false,
      "default": false
    }
  }
}
