{
  "collectionName": "components_blocks_feature_highlights",
  "info": {
    "displayName": "Feature Highlights",
    "icon": "star",
    "description": "Split tagline+title+body+image with a bordered horizontal row of icon-text highlights below."
  },
  "options": {},
  "attributes": {
    "tagline": {
      "type": "string",
      "required": false,
      "maxLength": 60
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "highlightedTitle": {
      "type": "string",
      "required": false,
      "maxLength": 200
    },
    "body": {
      "type": "text",
      "required": true,
      "maxLength": 600
    },
    "media": {
      "type": "component",
      "repeatable": false,
      "component": "blocks.media",
      "required": true
    },
    "imagePosition": {
      "type": "enumeration",
      "enum": ["left", "right"],
      "default": "right",
      "required": true
    },
    "highlights": {
      "type": "component",
      "repeatable": true,
      "component": "blocks.icon-text-item",
      "required": true,
      "min": 1,
      "max": 4
    }
  }
}
