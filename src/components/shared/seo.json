{
  "collectionName": "components_shared_seo",
  "info": {
    "displayName": "SEO",
    "icon": "search",
    "description": "SEO meta for a page or article. Per-locale."
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 60
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 160
    },
    "keywords": {
      "type": "text"
    },
    "metaRobots": {
      "type": "string"
    },
    "canonicalURL": {
      "type": "string"
    },
    "shareImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "metaSocial": {
      "type": "component",
      "repeatable": true,
      "component": "shared.meta-social"
    }
  }
}
