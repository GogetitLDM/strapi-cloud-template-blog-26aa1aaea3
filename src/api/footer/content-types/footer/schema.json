{
  "kind": "singleType",
  "collectionName": "footers",
  "info": {
    "singularName": "footer",
    "pluralName": "footers",
    "displayName": "Footer",
    "description": "Site-wide footer, rendered on every locale"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "logo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"],
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "ui": {
      "type": "component",
      "repeatable": false,
      "component": "footer.footer-ui",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "columns": {
      "type": "component",
      "repeatable": true,
      "component": "footer.link-column",
      "required": true,
      "min": 1,
      "max": 4,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "footer.social-link",
      "required": false,
      "max": 8,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "legalLinks": {
      "type": "component",
      "repeatable": true,
      "component": "navigation.link-item",
      "required": true,
      "min": 1,
      "max": 6,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
